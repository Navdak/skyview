{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "A dish or drink on the menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "isPopular": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A table booking request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "guests": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "date", "time", "guests", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer feedback and rating.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "rating", "comment"]
    },
    "Order": {
      "title": "Order",
      "description": "Food and drink order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "delivered", "cancelled"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "items", "totalAmount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/menuItems/{itemId}": {
      "schema": "MenuItem",
      "description": "Restaurant menu items"
    },
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Table bookings"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Customer reviews"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Food orders"
    }
  }
}
